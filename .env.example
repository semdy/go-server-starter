# Go Server Starter — Environment Variables
# Copy this file to .env and fill in your actual values.
# .env is gitignored and will never be committed.

# JWT
APP_JWT_TOKENSECRET=change-me-to-a-random-secret

# Database
APP_DATABASE_PASSWORD=change-me

# Redis
APP_REDIS_PASSWORD=change-me

# AsynQ task queue (typically same Redis, different DB)
APP_ASYNQ_REDISCONFIG_PASSWORD=change-me

# APP_ALIBABACLOUD_ACCESSKEYID="LTAI5t..."
# APP_ALIBABACLOUD_ACCESSSECRET="..."
# APP_ALIBABACLOUD_SMS_SIGNNAME="你的应用"
# APP_ALIBABACLOUD_SMS_TEMPLATECODE="SMS_123456789"
# APP_ALIBABACLOUD_EMAIL_FROMADDRESS="noreply@example.com"
# APP_ALIBABACLOUD_EMAIL_FROMNAME="Go Server Starter"
